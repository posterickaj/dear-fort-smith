---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="site-title">
			<a href="/">
				<img src="/images/dear-fort-smith-logo.svg" alt="" class="site-logo" />
				<span>{SITE_TITLE}</span>
			</a>
		</h2>

		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/platform">Playbook</HeaderLink>
			<HeaderLink href="/blog">Articles</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/maps">Maps</HeaderLink>
			<HeaderLink href="/memes">Memes</HeaderLink>
			<HeaderLink href="/newsletter">Newsletter</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1rem;
		background: var(--surface-raised);
		border-bottom: 1px solid var(--border);
		box-shadow: 0 2px 14px rgba(0, 0, 0, 0.28);
	}

	nav {
		max-width: 1100px;
		min-height: 64px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.site-title {
		margin: 0;
		font-size: 1rem;
		line-height: 1;
		flex-shrink: 0;
	}

	.site-title a {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		color: var(--text);
		text-decoration: none;
	}

	.site-title a:hover {
		color: rgb(var(--accent-light));
	}

	.site-logo {
		width: 28px;
		height: 44px;
		object-fit: contain;
		flex-shrink: 0;
		filter: brightness(0) invert(1);
		opacity: 0.95;
	}

	.internal-links {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		flex-wrap: wrap;
		gap: 0.1rem 0.55rem;
	}

	.internal-links a {
		padding: 1rem 0.35rem;
		color: var(--text-muted);
		border-bottom: 4px solid transparent;
		font-size: 0.95rem;
		font-weight: 700;
		text-decoration: none;
		white-space: nowrap;
	}

	.internal-links a:hover,
	.internal-links a.active {
		color: var(--text);
	}

	.internal-links a.active {
		border-bottom-color: rgb(var(--accent-light));
	}

	@media (max-width: 720px) {
		header {
			padding: 0.45rem 0.75rem;
		}

		nav {
			max-width: 100%;
			min-height: 0;
			justify-content: flex-start;
			gap: 0.75rem;
		}

		.site-title span {
			display: none;
		}

		.site-title a {
			gap: 0;
		}

		.site-logo {
			width: 22px;
			height: 34px;
		}

		.internal-links {
			flex: 1;
			display: flex;
			flex-wrap: nowrap;
			justify-content: flex-start;
			gap: 0.85rem;
			overflow-x: auto;
			white-space: nowrap;
			scrollbar-width: none;
			-webkit-overflow-scrolling: touch;
		}

		.internal-links::-webkit-scrollbar {
			display: none;
		}

		.internal-links a {
			flex-shrink: 0;
			padding: 0.45rem 0;
			border-bottom-width: 3px;
			font-size: 0.88rem;
		}
	}
</style>