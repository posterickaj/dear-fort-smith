---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'About | Dear Fort Smith,';
const description = 'About Dear Fort Smith.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />

		<main>
			<section class="about">
				<p class="eyebrow">Dear Fort Smith,</p>
				<h1>About</h1>

				<div class="about-card">
					<p>
						Dear Fort Smith is a civic archive for maps, articles, memes, field notes,
						public comments, and policy work focused on making Fort Smith safer, 
						financially solvent, and productive.
					</p>

					<p>
						The project connects local observations to a practical playbook: growth should
						pay for itself, infrastructure should be maintained before expansion, streets
						should be safe before they are fast, and land should be used productively.
					</p>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 760px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.about {
		max-width: 720px;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	h1 {
		margin: 0 0 1.5rem;
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1;
		color: var(--text);
	}

	.about-card {
		padding: 1.35rem;
		border: 1px solid var(--border);
		border-radius: 16px;
		background: var(--surface);
		box-shadow: var(--box-shadow);
	}

	p {
		margin: 0;
		color: var(--text-soft);
		line-height: 1.7;
		font-size: 1.1rem;
	}

	p + p {
		margin-top: 1.25rem;
	}

	@media (max-width: 720px) {
		main {
			padding: 2rem 1rem;
		}

		.about-card {
			padding: 1rem;
		}
	}
</style>