---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = posts[0];
const recentPosts = posts.slice(1, 3);

const formatTag = (tag: string) =>
	tag
		.replaceAll('-', ' ')
		.replace(/\b\w/g, (letter) => letter.toUpperCase());

const sections = [
	{
		title: 'Platform',
		description: 'The policy framework we need: solvency, safety, land use, infrastructure, and public finance.',
		href: '/platform',
	},
	{
		title: 'Articles',
		description: 'Essays, arguments, meeting notes, and local observations.',
		href: '/blog',
	},
	{
		title: 'Maps',
		description: 'Interactive maps and data projects about Fort Smith and Arkansas.',
		href: '/maps',
	},
	{
		title: 'Memes',
		description: 'A visual wall of urbanism arguments, maps, jokes, and article images.',
		href: '/memes',
	},
	{
		title: 'Projects',
		description: 'Calculators, tools, white papers, civic resources, and active campaigns.',
		href: '/projects',
	},
	{
		title: 'Newsletter',
		description: 'Newsletter about public safety. Full page coming later.',
		href: '/newsletter',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>

	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Dear Fort Smith,</p>
				<h1>Maps, memes, and math for a safe and productive city.</h1>
				<p class="intro">
					A civic archive for Fort Smith, Arkansas. Opinions, data, tools, and resources for understanding and improving our city.
					All content is free to read, share, and use.
				</p>
			</section>

			{featuredPost && (
				<section class="latest-section" aria-label="Latest article">
					<div class="section-heading">
						<h2>Latest article</h2>
						<a href="/blog">View all articles →</a>
					</div>

					<article class="featured-card">
						<a class="featured-image-link" href={`/blog/${featuredPost.id}/`}>
							{featuredPost.data.heroImage && (
								<img src={featuredPost.data.heroImage} alt={featuredPost.data.title} />
							)}
						</a>

						<div class="featured-content">
							<p class="date">
								<FormattedDate date={featuredPost.data.pubDate} />
							</p>

							<h3>
								<a href={`/blog/${featuredPost.id}/`}>
									{featuredPost.data.title}
								</a>
							</h3>

							<p>{featuredPost.data.description}</p>

							{featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
								<div class="tag-list" aria-label="Article tags">
									{featuredPost.data.tags.map((tag) => (
										<a class="tag" href={`/tags/${tag}`}>
											{formatTag(tag)}
										</a>
									))}
								</div>
							)}
						</div>
					</article>
				</section>
			)}

{recentPosts.length > 0 && (
	<section class="recent-section" aria-label="Recent articles">
		<h2>Recent articles</h2>

		<div class="recent-grid">
			{recentPosts.map((post) => (
				<article class="recent-card">
					<a href={`/blog/${post.id}/`}>
						<p class="date">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
					</a>
				</article>
			))}
		</div>
	</section>
)}

			<section class="portal-section" aria-label="Explore Dear Fort Smith">
				<h2>Site Contents</h2>

				<div class="portal-grid">
					{sections.map((section) => (
						<a class="portal-card" href={section.href}>
							<h3>{section.title}</h3>
							<p>{section.description}</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.hero {
		max-width: 850px;
		margin-bottom: 3rem;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.75rem, 7vw, 5rem);
		line-height: 0.95;
	}

	.intro {
		max-width: 720px;
		font-size: 1.2rem;
		line-height: 1.6;
	}

	.section-heading {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.section-heading h2,
	.recent-section h2,
	.portal-section h2 {
		margin: 0;
		font-size: 2rem;
	}

	.section-heading a {
		color: var(--accent);
		font-weight: 700;
		text-decoration: none;
	}

	.section-heading a:hover {
		text-decoration: underline;
	}

	.latest-section,
	.recent-section,
	.portal-section {
		margin-top: 3rem;
	}

	.featured-card {
		display: grid;
		grid-template-columns: 1.25fr 1fr;
		gap: 1.5rem;
		align-items: stretch;
		border: 1px solid rgba(var(--black), 0.12);
		border-radius: 16px;
		background: white;
		box-shadow: 0 2px 10px rgba(var(--black), 0.05);
		overflow: hidden;
	}

	.featured-image-link {
		display: block;
		background: black;
	}

	.featured-card img {
		display: block;
		width: 100%;
		height: 100%;
		min-height: 360px;
		object-fit: contain;
		background: black;
	}

	.featured-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 1.5rem;
	}

	.date {
		margin: 0 0 0.5rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.featured-content h3 {
		margin: 0 0 0.75rem;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
	}

	.featured-content h3 a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.featured-content h3 a:hover {
		color: rgb(var(--accent));
	}

	.featured-content p {
		line-height: 1.55;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.tag {
		display: inline-block;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--accent), 0.12);
		color: var(--accent);
		font-size: 0.85rem;
		font-weight: 700;
		text-decoration: none;
	}

	.tag:hover {
		background: rgba(var(--accent), 0.22);
	}

.recent-grid {
	display: grid;
	grid-template-columns: repeat(2, minmax(0, 1fr));
	gap: 0.85rem;
	margin-top: 1rem;
}

	.recent-card {
		border: 1px solid rgba(var(--black), 0.12);
		border-radius: 14px;
		background: white;
		box-shadow: 0 2px 10px rgba(var(--black), 0.05);
		overflow: hidden;
	}

.recent-card a {
	display: block;
	padding: 1rem;
	color: inherit;
	text-decoration: none;
}
	.recent-card h3 {
	margin: 0 0 0.5rem;
	font-size: 1.05rem;
	line-height: 1.2;
	}

	.recent-card p {
		margin: 0;
		line-height: 1.45;
	}

	.recent-card a:hover h3 {
		color: rgb(var(--accent));
	}

	.portal-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.portal-card {
		display: block;
		padding: 1.25rem;
		border: 1px solid rgba(var(--black), 0.12);
		border-radius: 14px;
		background: white;
		box-shadow: 0 2px 10px rgba(var(--black), 0.05);
		color: inherit;
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease;
	}

	.portal-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--box-shadow);
	}

	.portal-card h3 {
		margin: 0 0 0.5rem;
		font-size: 1.35rem;
	}

	.portal-card p {
		margin: 0;
		line-height: 1.5;
		color: rgb(var(--gray-dark));
	}

	@media (max-width: 850px) {
		.featured-card {
			grid-template-columns: 1fr;
		}

		.featured-card img {
			min-height: 240px;
		}

		.recent-grid,
		.portal-grid {
			grid-template-columns: 1fr;
		}

	}
</style>