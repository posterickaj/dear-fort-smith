---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'Maps | Dear Fort Smith,';
const description = 'Maps and data projects from Dear Fort Smith,';

const maps = [
	{
		title: 'Fort Smith Parking',
		description:
			'A map showing how much of our space is dedicated to parking. Parking is land, infrastructure, opportunity, and public cost.',
		url: 'https://fortsmithparking.netlify.app/',
		image: '/images/maps/fort-smith-parking-preview.png',
		tags: ['parking-reform', 'utilities', 'infill', 'do-the-math'],
	},
	{
		title: 'Fort Smith, 1951',
		description:
			'A historical street-network map showing Fort Smith before later waves of suburban expansion. Useful for seeing the compact city that existed before the current infrastructure footprint.',
		url: 'https://1951fortsmith.netlify.app/',
		image: '/images/maps/fort-smith-1951-preview.png',
		tags: ['infill', 'fix-it-first', 'do-the-math'],
	},
	{
		title: 'Fort Smith Traffic Heatmap',
		description:
			'Pulls ArDot traffic data to map traffic volumes across the city.',
		url: 'https://fortsmithtraffic.netlify.app/',
		image: '/images/maps/fort-smith-traffic.png',
		tags: ['no-new-roads', 'safe-streets', 'vmt'],
	},
	{
		title: 'Fort Smith Value Per Acre',
		description:
			'A value-per-acre map showing which places produce the most taxable value from the least land. This is the local balance sheet made visible.',
		url: 'https://fortsmithvpa.netlify.app/',
		image: '/images/maps/fort-smith-vpa-preview.png',
		tags: ['money-ball', 'balanced-budget', 'infill', 'do-the-math'],
	},
		{
		title: 'Fort Smith 2025 Business Licenses',
		description:
			'A map of 2025 business licenses in Fort Smith.',
		url: 'https://fortsmithbusinesslicenses.netlify.app/',
		image: '/images/maps/business-licenses-preview.png',
		tags: ['money-ball', 'parking-reform', 'do-the-math'],
	},
			{
		title: 'Fort Smith Roundabouts',
		description:
			'My map of roundabouts, roundabout-like rotaries, and "notabouts" (things that look like, but are not, roundabouts).',
		url: 'https://www.google.com/maps/d/edit?mid=15P0ObngpHxXRSbj_WPcDGJ-FeeiYHjE',
		image: '/images/maps/roundabouts_preview.png',
		tags: ['safe-streets'],
	},
				{
		title: 'Fort Smith Tresspaths',
		description:
			'My map of unofficial, unintended, or illegal paths for pedestrians to get through the city in ways that most people may not know about.',
		url: 'https://www.google.com/maps/d/edit?mid=1VPrdDAPgmEePSvKEa_fhruml2moatEM',
		image: '/images/maps/tresspaths_preview.png',
		tags: ['safe-streets','car-dependency'],
	},
					{
		title: 'Legacy Loop (Cancelled)',
		description:
			'My unofficial map of a proposed cycling and walking trail that was cancelled by the city.',
		url: 'https://www.google.com/maps/d/edit?mid=1qk6_prhfT_vXoZVpY2PChLcnAXxwYME',
		image: '/images/maps/original-legacy-loop.png',
		tags: ['safe-streets','car-dependency'],
	},
	{
		title: 'Arkansas Crash Analytics Tool',
		description:
			'A map showing the location and severity of traffic crashes across Arkansas. This is a tool for humbly observing where people struggle most.',
		url: 'https://gis.ardot.gov/portal/apps/dashboards/3ae35f942fa340888abd27f26d405558',
		image: '/images/maps/acat-preview.png',
		tags: ['safe-streets', 'vmt', 'street-hierarchy', 'money-ball', 'car-dependency', 'fix-it-first', 'do-the-math'],
		external: true,
	},
		{
		title: 'Fort Smith Public GIS Viewer',
		description:
			'A map showing the master street plan, city-owned parcels, zip codes, parks, airport zoning, assessments, zoning, and land-use.',
		url: 'https://gis.fortsmithar.gov/portal/apps/experiencebuilder/experience/?id=8b5d8c81a19540d7853228b73ef70ad1',
		image: '/images/maps/public-gis-preview.png',
		tags: ['money-ball', 'do-the-math'],
		external: true,
	},
	{
		title: 'Strava Heatmap',
		description:
			'GPS-based heatmap data showing where people are actually moving in Fort Smith. It is not a complete picture, but it is a useful glimpse at local movement patterns.',
		url: 'https://www.strava.com/maps/global-heatmap',
		image: '/images/maps/strava-preview.png',
		tags: ['safe-streets', 'vmt', 'street-hierarchy', 'money-ball', 'car-dependency', 'fix-it-first', 'do-the-math'],
		external: true,
	},
];

const formatTag = (tag: string) =>
	tag
		.replaceAll('-', ' ')
		.replace(/\b\w/g, (letter) => letter.toUpperCase());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />

		<main>
			<section class="page-header">
				<p class="eyebrow">Dear Fort Smith,</p>
				<h1>Maps</h1>
				<p>
					Interactive maps and data projects for understanding Fort Smith’s land use,
					infrastructure burden, traffic patterns, and public finance.
				</p>
			</section>

			<section class="map-grid" aria-label="Map projects">
				{maps.map((map) => (
					<article class="map-card">
						<a class="map-image-link" href={map.url} target="_blank" rel="noopener noreferrer">
							<img src={map.image} alt={`${map.title} preview`} loading="lazy" />
						</a>

						<div class="map-content">
							<div class="map-heading">
								<h2>{map.title}</h2>

								{map.external && (
									<span class="external-pill">External</span>
								)}
							</div>

							<p>{map.description}</p>

							{map.tags.length > 0 && (
								<div class="tag-list" aria-label="Related tags">
									{map.tags.map((tag) => (
										<a class="tag" href={`/tags/${tag}`}>
											{formatTag(tag)}
										</a>
									))}
								</div>
							)}

							<a class="open-map" href={map.url} target="_blank" rel="noopener noreferrer">
								Open map →
							</a>
						</div>
					</article>
				))}
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.page-header {
		max-width: 760px;
		margin-bottom: 2.5rem;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1;
		color: var(--text);
	}

	.page-header p {
		margin: 0;
		max-width: 720px;
		line-height: 1.6;
		font-size: 1.1rem;
		color: var(--text-soft);
	}

	.map-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.map-card {
		display: grid;
		grid-template-rows: auto 1fr;
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 16px;
		background: var(--surface);
		box-shadow: var(--box-shadow);
		color: var(--text);
	}

	.map-image-link {
		display: block;
		background: black;
		text-decoration: none;
	}

	.map-card img {
		display: block;
		width: 100%;
		height: 260px;
		object-fit: cover;
		border-radius: 0;
		transition:
			opacity 180ms ease,
			transform 180ms ease;
	}

	.map-image-link:hover img {
		opacity: 0.9;
		transform: scale(1.01);
	}

	.map-content {
		display: flex;
		flex-direction: column;
		min-width: 0;
		padding: 1.25rem;
	}

	.map-heading {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.75rem;
	}

	.map-content h2 {
		margin: 0;
		color: var(--text);
		font-size: clamp(1.35rem, 3vw, 2rem);
		line-height: 1.1;
		overflow-wrap: anywhere;
	}

.external-pill {
	flex-shrink: 0;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	padding: 0.32rem 0.65rem;
	border: 1px solid rgba(251, 191, 36, 0.45);
	border-radius: 999px;
	background: rgba(251, 191, 36, 0.16);
	color: #fbbf24;
	font-size: 0.72rem;
	font-weight: 900;
	line-height: 1;
	text-transform: uppercase;
	letter-spacing: 0.05em;
}

	.map-content p {
		margin: 0;
		color: var(--text-soft);
		line-height: 1.55;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 1rem;
	}

	.tag {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.28rem 0.6rem;
		border: 1px solid rgba(var(--accent-light), 0.18);
		border-radius: 999px;
		background: rgba(var(--accent), 0.2);
		color: rgb(var(--accent-light));
		font-size: 0.76rem;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
	}

	.tag:hover {
		background: rgba(var(--accent), 0.3);
		color: var(--text);
	}

	.open-map {
		margin-top: auto;
		padding-top: 1.25rem;
		color: rgb(var(--accent-light));
		font-weight: 800;
		text-decoration: none;
	}

	.open-map:hover {
		color: var(--text);
		text-decoration: underline;
	}

	@media (max-width: 800px) {
		main {
			padding: 2rem 1rem;
		}

		.map-grid {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}

		.map-card img {
			height: 220px;
		}

		.map-content {
			padding: 1rem;
		}

		.map-heading {
			flex-direction: column;
			gap: 0.6rem;
		}
	}
</style>