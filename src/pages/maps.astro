---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'Maps | Dear Fort Smith,';
const description = 'Maps and data projects from Dear Fort Smith,';

const maps = [
	{
		title: 'Fort Smith Parking',
		description:
			'A map showing how much of our space is dedicated to parking. Parking is land, infrastructure, opportunity, and public cost.',
		url: 'https://fortsmithparking.netlify.app/',
		image: '/images/maps/fort-smith-parking-preview.png',
		tags: ['parking-reform', 'utilities', 'infill', 'do-the-math'],
	},
	{
		title: 'Fort Smith, 1951',
		description:
			'A historical street-network map showing Fort Smith before later waves of suburban expansion. Useful for seeing the compact city that existed before the current infrastructure footprint.',
		url: 'https://1951fortsmith.netlify.app/',
		image: '/images/maps/fort-smith-1951-preview.png',
		tags: ['infill', 'fix-it-first', 'do-the-math'],
	},
	{
		title: 'Arkansas Traffic Volume',
		description:
			'A traffic-volume map for comparing roadway demand, expansion pressure, and the public cost of designing solely for car throughput.',
		url: 'https://arkansastrafficvlolume.netlify.app/',
		image: '/images/maps/arkansas-traffic-volume-preview.png',
		tags: ['no-new-roads', 'safe-streets', 'vmt', 'do-the-math'],
	},
	{
		title: 'Fort Smith Value Per Acre',
		description:
			'A value-per-acre map showing which places produce the most taxable value from the least land. This is the local balance sheet made visible.',
		url: 'https://fortsmithvpa.netlify.app/',
		image: '/images/maps/fort-smith-vpa-preview.png',
		tags: ['money-ball', 'balanced-budget', 'infill', 'do-the-math'],
	},
		{
		title: 'Arkansas Crash Analytics Tool',
		description:
			'EXTERNAL: A map showing the location and severity of traffic crashes across Arkansas. This is a tool for humbly observing where people struggle most.',
		url: 'https://gis.ardot.gov/portal/apps/dashboards/3ae35f942fa340888abd27f26d405558',
		image: '/images/maps/acat-preview.png',
		tags: ['safe-streets', 'vmt', 'street-hierarchy', 'money-ball', 'car-dependency', 'fix-it-first', 'do-the-math'],
	},
];

const formatTag = (tag: string) =>
	tag
		.replaceAll('-', ' ')
		.replace(/\b\w/g, (letter) => letter.toUpperCase());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<section class="page-header">
				<p class="eyebrow">Dear Fort Smith,</p>
				<h1>Maps</h1>
				<p>
					Interactive maps and data projects for understanding Fort Smith’s land use,
					infrastructure burden, traffic patterns, and public finance.
				</p>
			</section>

			<section class="map-grid" aria-label="Map projects">
				{maps.map((map) => (
					<article class="map-card">
						<a class="map-image-link" href={map.url} target="_blank" rel="noopener noreferrer">
							<img src={map.image} alt={`${map.title} preview`} />
						</a>

						<div class="map-content">
							<h2>{map.title}</h2>
							<p>{map.description}</p>

							<div class="tag-list" aria-label="Related tags">
								{map.tags.map((tag) => (
									<a class="tag" href={`/tags/${tag}`}>
										{formatTag(tag)}
									</a>
								))}
							</div>

							<a class="open-map" href={map.url} target="_blank" rel="noopener noreferrer">
								Open map →
							</a>
						</div>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.page-header {
		max-width: 760px;
		margin-bottom: 2.5rem;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1;
	}

	.page-header p {
		line-height: 1.6;
		font-size: 1.1rem;
	}

	.map-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.map-card {
		display: grid;
		grid-template-rows: auto 1fr;
		border: 1px solid rgba(var(--black), 0.12);
		border-radius: 14px;
		background: white;
		box-shadow: 0 2px 10px rgba(var(--black), 0.05);
		overflow: hidden;
	}

	.map-image-link {
		display: block;
		background: black;
	}

	.map-card img {
		display: block;
		width: 100%;
		height: 260px;
		object-fit: cover;
		transition: 0.2s ease;
	}

	.map-image-link:hover img {
		opacity: 0.88;
	}

	.map-content {
		display: flex;
		flex-direction: column;
		padding: 1.25rem;
	}

	.map-content h2 {
		margin: 0 0 0.75rem;
		line-height: 1.15;
	}

	.map-content p {
		margin: 0;
		line-height: 1.55;
		color: rgb(var(--gray-dark));
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.tag {
		display: inline-block;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--accent), 0.12);
		color: var(--accent);
		font-size: 0.85rem;
		font-weight: 700;
		text-decoration: none;
	}

	.tag:hover {
		background: rgba(var(--accent), 0.22);
	}

	.open-map {
		margin-top: auto;
		padding-top: 1.25rem;
		color: var(--accent);
		font-weight: 700;
		text-decoration: none;
	}

	.open-map:hover {
		text-decoration: underline;
	}

	@media (max-width: 800px) {
		.map-grid {
			grid-template-columns: 1fr;
		}

		.map-card img {
			height: 220px;
		}
	}
</style>