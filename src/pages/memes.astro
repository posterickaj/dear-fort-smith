---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const posts = (await getCollection('blog'))
	.filter((post) => post.data.heroImage)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Memes | Dear Fort Smith,';
const description = 'Articles with no headlines and sorted randomly.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />

		<main>
			<section class="page-header">
				<p class="eyebrow">Dear Fort Smith,</p>
				<h1>Memes</h1>
				<p>
					Articles with no headlines and sorted randomly.
				</p>

				<button id="shuffleButton" type="button">Shuffle the wall</button>
			</section>

			<section class="meme-wall" aria-label="Visual article wall">
				{posts.map((post) => (
					<a class="meme-card" href={`/blog/${post.id}/`}>
						<img src={post.data.heroImage} alt={post.data.title} />
						<div class="meme-title">
							<span>{post.data.title}</span>
						</div>
					</a>
				))}
			</section>
		</main>

		<Footer />

		<script>
			function shuffleWall() {
				const wall = document.querySelector('.meme-wall');
				const cards = Array.from(document.querySelectorAll('.meme-card'));

				for (let i = cards.length - 1; i > 0; i--) {
					const j = Math.floor(Math.random() * (i + 1));
					[cards[i], cards[j]] = [cards[j], cards[i]];
				}

				cards.forEach((card) => wall?.appendChild(card));
			}

			shuffleWall();

			document.getElementById('shuffleButton')?.addEventListener('click', shuffleWall);
		</script>
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.page-header {
		max-width: 760px;
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1;
		color: var(--text);
	}

	.page-header p {
		margin: 0;
		line-height: 1.6;
		font-size: 1.1rem;
		color: var(--text-soft);
	}

	button {
		margin-top: 1rem;
		padding: 0.55rem 0.9rem;
		border: 1px solid rgba(var(--accent-light), 0.22);
		border-radius: 999px;
		background: rgba(var(--accent), 0.2);
		color: rgb(var(--accent-light));
		font-weight: 800;
		cursor: pointer;
	}

	button:hover {
		background: rgba(var(--accent), 0.3);
		color: var(--text);
	}

	.meme-wall {
		columns: 280px;
		column-gap: 1rem;
	}

	.meme-card {
		position: relative;
		display: block;
		width: 100%;
		margin: 0 0 1rem;
		break-inside: avoid;
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 14px;
		background: black;
		box-shadow: var(--box-shadow);
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease,
			opacity 160ms ease;
	}

	.meme-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
	}

	.meme-card:focus-visible {
		outline: 3px solid rgb(var(--accent-light));
		outline-offset: 3px;
	}

	.meme-card img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0;
	}

	.meme-title {
		position: absolute;
		inset: auto 0 0 0;
		padding: 2.4rem 0.75rem 0.75rem;
		background: linear-gradient(
			to top,
			rgba(0, 0, 0, 0.9),
			rgba(0, 0, 0, 0.48),
			rgba(0, 0, 0, 0)
		);
		color: white;
		opacity: 0;
		transition: opacity 160ms ease;
	}

	.meme-card:hover .meme-title,
	.meme-card:focus-visible .meme-title {
		opacity: 1;
	}

	.meme-title span {
		display: block;
		font-size: clamp(0.95rem, 2.4vw, 1.35rem);
		font-weight: 800;
		line-height: 1.08;
		letter-spacing: -0.015em;
		-webkit-text-stroke: 0.9px rgba(0, 0, 0, 0.95);
		text-shadow:
			1px 1px 0 rgba(0, 0, 0, 0.95),
			-1px 1px 0 rgba(0, 0, 0, 0.95),
			1px -1px 0 rgba(0, 0, 0, 0.95),
			-1px -1px 0 rgba(0, 0, 0, 0.95),
			0 2px 4px rgba(0, 0, 0, 0.95),
			0 0 10px rgba(0, 0, 0, 0.9);
	}

	@media (max-width: 720px) {
		main {
			padding: 2rem 1rem;
		}

		.meme-wall {
			columns: 2;
			column-gap: 0.75rem;
		}

		.meme-card {
			margin-bottom: 0.75rem;
		}

.meme-title {
	display: none;
}

	}

	@media (max-width: 420px) {
		.meme-wall {
			columns: 1;
		}

		.meme-title span {
			font-size: clamp(0.95rem, 5vw, 1.2rem);
		}
	}
</style>