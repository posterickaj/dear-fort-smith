---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'Playbook | Dear Fort Smith,';
const description = 'My playbook for a safer, solvent, and productive city.';

const platformCategories = [
	{
		id: 'police-fire',
		title: 'Police & Fire',
		description:
			'Reduce preventable harm before emergency response is needed.',
		items: [
			{
				id: 'eyes-on-the-street',
				title: 'Eyes on the Street',
				text: 'Leverage economic activity, housing, and foot traffic to increase natural surveillance and discourage anti-social behavior.',
			},
			{
				id: 'police-visibility',
				title: 'Police Visibility',
				text: 'Increase human-scale police presence at all hours through community policing, foot patrols, bike patrols, and visible neighborhood engagement.',
			},
			{
				id: 'single-stair',
				title: 'Single Stair',
				text: 'Legalize single-stair buildings if they meet enhanced fire-safety, building-safety, and accessibility standards.',
			},
			{
				id: 'smaller-trucks',
				title: 'Smaller Fire Trucks',
				text: 'So long as trucks are cheaper than roads, fund the Fire Department with smaller, more maneuverable fire trucks for use in areas with a more traditional, compact urban form.',
			},
						{
				id: 'smaller-elevators',
				title: 'Smaller Elevators',
				text: 'Legalize smaller elevators in residential buildings to improve accessibility and reduce construction costs.',
			},
		],
	},
	{
		id: 'parks-public-spaces',
		title: 'Parks & Public Spaces',
		description:
			'Make neighborhoods useful.',
		items: [
			{
				id: 'tactical-urbanism',
				title: 'Legalize Tactical Urbanism',
				text: 'Create a simple permit process for temporary street improvements, parklets, planters, paint, curb extensions, and safety demonstrations.',
			},

			{
				id: 'linear-parks',
				title: 'Place parks near housing',
				text: 'Maximize the return on value for parks by putting them near as much housing as possible. Linear parks serve the largest number of homes for the lowest cost.',
			},
		],
	},
	{
		id: 'neighborhood-services',
		title: 'Neighborhood Services',
		description:
			'Make Fort Smith livable.',
		items: [
			{
				id: 'small-business-reform',
				title: 'Neighborhood Enterprise',
				text: 'Legalize neighborhood-scale shops, cafés, offices, childcare, schools, clinics, home businesses, live-work spaces, and other useful daily services within walking distance of homes.',
			},
			{
				id: 'incremental-development',
				title: 'Legalize Housing',
				text: 'Allow ADUs, duplexes, triplexes, cottage courts, small apartments, and mixed-use buildings in every neighborhood.',
			},
			{
				id: 'infill',
				title: 'Infill First',
				text: 'Incentivize development in vacant lots and underused parcels before extending infrastructure outward.',
			},
		],
	},
	{
		id: 'planning-zoning',
		title: 'Planning & Zoning',
		description:
			'Productive development patterns and reductions to artificial scarcity.',
		items: [
			{
				id: 'parking-reform',
				title: 'End Parking Mandates',
				text: 'Remove minimum parking requirements and let land be used for productive buildings, businesses, housing, and public life.',
			},
			{
				id: 'street-hierarchy',
				title: 'Hexagonal Network Topology',
				text: 'Develop a modern street-network configuration that learns from the failures of older hierarchical models.',
			},
						{
				id: 'form-based-code',
				title: 'Form-Based Code',
				text: 'Protect, nurture, and expand the downtown form-based code.',
			},
						{
				id: 'balanced-budget',
				title: 'Growth Pays Its Own Way',
				text: 'New developments, extensions, and subdivisions should prove they can cover their long-term public costs.',
			},
		],
	},
	{
		id: 'streets-traffic',
		title: 'Streets & Traffic',
		description:
			'Safer streets, lower transportation costs, and less financially destructive roadway expansion.',
		items: [
			{
				id: 'safe-streets',
				title: 'Safety First',
				text: 'Design streets that prioritize financial productivity and safety over merely moving as many cars as quickly as possible.',
			},
			{
				id: 'no-new-roads',
				title: 'No New Roads',
				text: 'Require lifecycle replacement cost, induced-demand, and land-use productivity analysis before any new road construction.',
			},
			{
				id: 'vmt',
				title: 'Vehicle Miles Traveled Traffic Analysis',
				text: 'Allow developers to substitute a Vehicle-Miles-Traveled analysis instead of a Level-of-Service analysis to measure traffic impacts.',
			},
			{
				id: 'car-dependency',
				title: 'Mobility for All',
				text: 'Design streets and networks that give real access and mobility to walkers, cyclists, wheelchair users, transit riders, and micromobility users.',
			},
		],
	},
	{
		id: 'transit',
		title: 'Transit',
		description:
			'Transit that is useful, more frequent, and more financially coherent.',
		items: [
			{
				id: 'ridership-first-transit',
				title: 'Ridership-First Transit',
				text: 'Prioritize transit routes and service design around ridership rather than maximum geographic coverage. This lowers cost per passenger mile and allows the city to improve service frequency.',
			},
			{
				id: 'transit-orientation',
				title: 'Transit-Oriented Development',
				text: 'Encourage housing, jobs, schools, services, and public activity near useful transit corridors so buses serve more people with fewer wasted miles.',
			},
		],
	},
	{
		id: 'utilities',
		title: 'Utilities',
		description:
			'Make water, sewer, drainage, and infrastructure costs visible.',
		items: [
			{
				id: 'utilities',
				title: 'Utility Pricing That Reflects Infrastructure Burden',
				text: 'Tie utility and street taxes more closely to the parcels and development patterns that create the greatest infrastructure burden.',
			},
			{
				id: 'fix-it-first',
				title: 'Fix It First Infrastructure',
				text: 'Maintain existing streets, pipes, sidewalks, drainage, parks, and public buildings before expanding outward.',
			},

		],
	},
	{
		id: 'finance-administration',
		title: 'Finance & Administration',
		description:
			'Policies for budgeting, reporting, measurement, and municipal decision-making.',
		items: [
			{
				id: 'do-the-math',
				title: 'Measure Net Income',
				text: 'Measure and publish neighborhood-level revenues, costs, assets, liabilities, vacancy rates, crashes, infrastructure age, and other practical indicators.',
			},
			{
				id: 'finance-decoder',
				title: 'Add Finance Decoder to Reports',
				text: 'Add plain-language balance sheet equations to the annual financial report so residents can see whether the city is getting stronger or weaker.',
			},
			{
				id: 'money-ball',
				title: 'Moneyball for City Government',
				text: 'Use small, measurable, high-return public investments instead of defaulting to large projects whose benefits are difficult to prove.',
			},
			{
				id: 'citizens-dividend',
				title: 'Capture Economic Rent',
				text: 'Measure community-created wealth, then return its appreciation to the public through a citizens dividend.',
			},

		],
	},
	{
		id: 'economic-development',
		title: 'Economic Development',
		description:
			'Reward productive land use, local enterprise, and financially durable growth.',
		items: [
			{
				id: 'single-tax',
				title: 'One Tax Downtown',
				text: 'Pilot an Economic Development Zone that reduces taxes on building improvements and sales while shifting the burden toward land.',
			},
		],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<p class="eyebrow">Dear Fort Smith,</p>
				<h1>Playbook</h1>

				<p class="intro">
					My playbook for a safer, solvent, and productive city.
				</p>

				<p class="tag-note">
					Each item also functions as a tag for articles and memes on the site.
				</p>
			</section>

			<section class="category-grid" aria-label="Playbook categories">
				{platformCategories.map((category) => (
					<details class="category" id={category.id}>
						<summary>
							<div class="summary-content">
								<div>
									<h2>{category.title}</h2>
									<p>{category.description}</p>
								</div>

								<div class="summary-footer">
									<span class="count">{category.items.length} items</span>
									<span class="expand-pill">
										<span class="show-text">Show items</span>
										<span class="hide-text">Hide items</span>
									</span>
								</div>
							</div>
						</summary>

						<div class="platform-reveal">
							<ol class="platform-list">
								{category.items.map((item) => (
<li id={`${category.id}-${item.id}`}>
	<div class="item-header">
		<a
			class="anchor-link"
			href={`#${category.id}-${item.id}`}
			aria-label={`Link to ${item.title}`}
		>
			#
		</a>
		<strong>{item.title}</strong>
	</div>

	<p class="item-text">{item.text}</p>

	<a
		class="platform-tag"
		href={`/tags/${item.id}`}
		aria-label={`View articles tagged ${item.id}`}
	>
		<span>Tag:</span>
		<code>{item.id}</code>
	</a>
</li>
								))}
							</ol>
						</div>
					</details>
				))}
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.hero {
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.25rem, 6vw, 4rem);
		line-height: 1;
		color: var(--text);
	}

	.intro {
		max-width: 720px;
		font-size: 1.2rem;
		line-height: 1.6;
		color: var(--text-soft);
	}

	.tag-note {
		max-width: 720px;
		margin-top: 1rem;
		padding: 1rem;
		border-left: 4px solid rgb(var(--accent-light));
		background: rgba(var(--accent), 0.12);
		color: var(--text-soft);
		line-height: 1.5;
	}

	.category-grid {
		display: grid;
		gap: 1rem;
		margin-top: 2rem;
	}

	.category {
		border: 1px solid var(--border);
		border-radius: 14px;
		background: var(--surface);
		box-shadow: var(--box-shadow);
		color: var(--text);
		overflow: hidden;
	}

	.category summary {
		display: block;
		padding: 1.25rem;
		cursor: pointer;
		list-style: none;
	}

	.category summary::-webkit-details-marker {
		display: none;
	}

	.category summary::marker {
		content: '';
	}

	.summary-content {
		display: grid;
		gap: 1rem;
	}

	.category h2 {
		margin: 0;
		font-size: 1.75rem;
		line-height: 1.15;
		color: var(--text);
	}

	.category summary p {
		margin: 0.5rem 0 0;
		line-height: 1.45;
		color: var(--text-muted);
	}

	.summary-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.25rem;
	}

	.count {
		white-space: nowrap;
		color: var(--text-muted);
		font-size: 0.95rem;
	}

	.expand-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--accent), 0.22);
		color: rgb(var(--accent-light));
		font-size: 0.85rem;
		font-weight: 700;
	}

	.hide-text {
		display: none;
	}

	.category[open] .show-text {
		display: none;
	}

	.category[open] .hide-text {
		display: inline;
	}

	.platform-reveal {
		background: var(--surface-soft);
		border-top: 1px solid var(--border);
		padding: 1.25rem;
	}

	.category[open] .platform-reveal {
		animation: revealTags 300ms ease-out both;
	}

	.platform-list {
		display: grid;
		gap: 0.85rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.platform-list li {
		display: grid;
		grid-template-columns: 220px minmax(0, 1fr) 190px;
		gap: 1rem;
		align-items: start;
		padding: 1rem;
		border: 1px solid var(--border);
		border-radius: 10px;
		background: var(--surface-tinted);
		color: var(--text);
		scroll-margin-top: 5rem;
	}

	.item-header {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		min-width: 0;
	}

	.platform-list strong {
		color: var(--text);
		font-size: 0.95rem;
		line-height: 1.35;
	}

	.item-text {
		margin: 0;
		color: var(--text-soft);
		line-height: 1.5;
	}

	.anchor-link {
		flex-shrink: 0;
		color: rgb(var(--accent-light));
		font-weight: 800;
		text-decoration: none;
	}

	.anchor-link:hover {
		color: rgb(var(--accent));
	}

	.platform-tag {
		justify-self: end;
		align-self: start;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		max-width: 100%;
		padding: 0.35rem 0.65rem;
		border: 1px solid rgba(var(--accent-light), 0.22);
		border-radius: 999px;
		background: rgba(var(--accent), 0.2);
		color: var(--text-muted);
		font-size: 0.68rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
		white-space: nowrap;
		text-decoration: none;
	}

	.platform-tag:hover {
	background: rgba(var(--accent), 0.32);
	color: var(--text);
}

	.platform-tag code {
		all: unset;
		color: rgb(var(--accent-light));
		font-size: 0.68rem;
		font-weight: 800;
		line-height: 1;
	}

	@keyframes revealTags {
		from {
			opacity: 0;
			transform: translateY(-0.75rem);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 800px) {
		main {
			padding: 2rem 1rem;
		}

		.count {
			display: none;
		}

		.platform-list li {
			grid-template-columns: 1fr;
			gap: 0.75rem;
		}

		.platform-tag {
			justify-self: start;
			white-space: normal;
			line-height: 