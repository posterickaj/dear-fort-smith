---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'Projects | Dear Fort Smith,';
const description =
	'Projects, calculators, white papers, campaigns, and civic tools from Dear Fort Smith,';

type ProjectItem = {
	title: string;
	status: string;
	description: string;
	url?: string;
	coverageUrl?: string;
	coverageLabel?: string;
	tags: string[];
	image?: string;
	imageAlt?: string;
};

type ProjectCategory = {
	id: string;
	title: string;
	description: string;
	items: ProjectItem[];
};

const projectCategories: ProjectCategory[] = [
	{
		id: 'active-tools',
		title: 'Tools & Public Resources',
		description: 'Items I made to engage the public.',
		items: [
			{
				title: 'Fort Smith Frontage Levy Calculator',
				status: 'Live',
				description:
					'A calculator for estimating how a frontage-based water billing structure could affect monthly water bills.',
				url: 'https://fswatercalc.com/',
				tags: ['utilities', 'balanced-budget', 'do-the-math'],
			},
			{
				title: 'Frontage Levy Slide Deck',
				status: 'Live',
				description:
					'The full presentation explaining the water billing proposal, fixed infrastructure costs, and frontage-based pricing logic.',
				url: 'https://docs.google.com/presentation/d/1GMZU_PEcrNZK8DgDXeY_SoCR5la8GR1QDsSA2rheA1U/edit?usp=sharing',
				tags: ['utilities', 'balanced-budget', 'do-the-math'],
			},
			{
				title: 'Fort Smith Community Calendar',
				status: 'Cancelled',
				description: 'A public calendar for Fort Smith events and civic activity.',
				url: 'https://www.fortsmithcalendar.com/',
				tags: ['public-land'],
			},
		],
	},
	{
		id: 'safety-projects',
		title: 'Safety Projects',
		description:
			'Projects focused on street safety, public safety, and reducing preventable harm.',
		items: [
			{
				title: 'For Safety',
				status: 'Active',
				description:
					'A privately distributed quarterly newsletter about public safety improvements.',
				url: '/newsletter',
				tags: ['safe-streets'],
			},
			{
				title: 'Reflectors',
				status: 'Active',
				description:
					'I distribute personal reflectors which can be clipped to clothing to improve visibility. Fort Smith Police cruisers carry them to give to vulnerable road users at night. I also give them out on Halloween.',
				coverageUrl:
					'https://www.strongtowns.org/journal/2026-7-1-the-reflector-that-started-a-conversation',
				coverageLabel: 'Strong Towns',
				tags: ['safe-streets'],
				image: '/images/reflector.jpg',
				imageAlt: 'A pedestrian reflector attached to a backpack.',
			},
			{
				title: 'Project Right-Of-Way',
				status: 'Pending',
				description:
					'A proposed Fort Smith safety task force involving residents, police, streets, and planning staff.',
				url: '',
				tags: ['safe-streets', 'public-land'],
			},
			{
				title: 'The Death of a Child Is Not a Fluke',
				status: 'Published',
				description:
					'An op-ed about roadway danger, budgeting priorities, and the consequences of reproducing deadly street designs.',
				url: 'https://talkbusiness.net/2025/09/the-death-of-a-child-is-not-a-fluke/',
				tags: ['safe-streets', 'no-new-roads'],
			},
		],
	},
	{
		id: 'finance-policy',
		title: 'Finance & Tax Policy',
		description:
			'Projects about municipal finance, tax structure, and local fiscal accountability.',
		items: [
			{
				title: 'NWA Finance Decoder',
				status: 'Live',
				description:
					'A comparison of the financials of Fayetteville, Springdale, Bentonville, Siloam Springs, and Fort Smith.',
				url: 'https://aaroncaldwell.us/arkansas_financial_decoder/',
				tags: ['balanced-budget', 'do-the-math', 'finance-decoder'],
			},
			{
				title: 'SJR15: Economic Development Districts',
				status: 'Research',
				description:
					'A proposed constitutional amendment that could allow Arkansas cities to experiment with special local tax structures.',
				url: 'https://arktimes.com/arkansas-blog/2025/04/14/an-amendment-to-give-big-local-tax-breaks-to-developers-appears-headed-for-the-ballot',
				tags: ['single-tax', 'balanced-budget'],
			},
			{
				title: 'LVT / Single-Tax Proposal',
				status: 'Concept',
				description:
					'A proposed Fort Smith tax structure connected to SJR15 and downtown economic development.',
				url: '',
				tags: ['single-tax', 'infill', 'balanced-budget'],
			},
		],
	},
	{
		id: 'future-research',
		title: 'Future Research & Side Projects',
		description: 'Longer-term research ideas and civic-adjacent projects.',
		items: [
			{
				title: 'School Drop-Off Analysis',
				status: 'Potential 2028 Project',
				description:
					'A proposed analysis comparing school drop-off procedures in the Fort Smith metro by safety, cost, throughput, and speed.',
				url: '',
				tags: ['safe-streets', 'do-the-math'],
			},
			{
				title: 'single.stair AR',
				status: 'Pending',
				description:
					'A state-level fire code review effort focused on small buildings, old buildings, and code reform.',
				url: '',
				tags: ['incremental-development', 'infill'],
			},
			{
				title: 'Escape from Arkansas',
				status: 'Likely 2027',
				description:
					'A small-team video game project reviving an older genre of games, built around crossing Arkansas.',
				url: '',
				tags: [],
			},
		],
	},
];

const formatTag = (tag: string) =>
	tag
		.replaceAll('-', ' ')
		.replace(/\b\w/g, (letter) => letter.toUpperCase());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<p class="eyebrow">Dear Fort Smith,</p>
				<h1>Projects</h1>

				<p class="intro">
					Calculators, white papers, civic tools, safety efforts, and policy
					projects that sit outside the normal article and map archive.
				</p>
			</section>

			<section class="project-grid" aria-label="Project categories">
				{projectCategories.map((category) => (
					<details class="project-category" id={category.id}>
						<summary>
							<div class="summary-content">
								<div>
									<h2>{category.title}</h2>
									<p>{category.description}</p>
								</div>

								<div class="summary-footer">
									<span class="count">{category.items.length} projects</span>
									<span class="expand-pill">
										<span class="show-text">Show projects</span>
										<span class="hide-text">Hide projects</span>
									</span>
								</div>
							</div>
						</summary>

						<div class="project-reveal">
							<div class="project-list">
								{category.items.map((project) => (
									<article class={`project-card ${project.image ? 'has-image' : ''}`}>
										<div class="project-copy">
											<div class="project-card-header">
												<p class="status">{project.status}</p>

												{!project.image && (
													project.url ? (
														<a
															class="project-link"
															href={project.url}
															target={project.url.startsWith('http') ? '_blank' : undefined}
															rel={project.url.startsWith('http') ? 'noopener noreferrer' : undefined}
														>
															Open project →
														</a>
													) : (
														<span class="project-link muted">No public link yet</span>
													)
												)}
											</div>

											<h3>{project.title}</h3>

											<p class="project-description">{project.description}</p>

											{project.coverageUrl && (
												<a
													class="coverage-link"
													href={project.coverageUrl}
													target="_blank"
													rel="noopener noreferrer"
												>
													Featured by {project.coverageLabel ?? 'another publication'} →
												</a>
											)}

											{project.tags.length > 0 && (
												<div class="tag-list" aria-label="Related tags">
													{project.tags.map((tag) => (
														<a class="tag" href={`/tags/${tag}`}>
															{formatTag(tag)}
														</a>
													))}
												</div>
											)}
										</div>

										{project.image && (
											<div class="project-side">
												{project.url && (
													<a
														class="project-link side-link"
														href={project.url}
														target={project.url.startsWith('http') ? '_blank' : undefined}
														rel={project.url.startsWith('http') ? 'noopener noreferrer' : undefined}
													>
														Open project →
													</a>
												)}

												<div class="project-image-wrap">
													<img
														class="project-image"
														src={project.image}
														alt={project.imageAlt ?? ''}
														loading="lazy"
													/>
												</div>
											</div>
										)}
									</article>
								))}
							</div>
						</div>
					</details>
				))}
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.hero {
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1;
		color: var(--text);
	}

	.intro {
		max-width: 720px;
		font-size: 1.15rem;
		line-height: 1.6;
		color: var(--text-soft);
	}

	.project-grid {
		display: grid;
		gap: 1rem;
		margin-top: 2rem;
	}

	.project-category {
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 16px;
		background: var(--surface);
		box-shadow: var(--box-shadow);
		color: var(--text);
	}

	.project-category summary {
		display: block;
		padding: 1.25rem;
		cursor: pointer;
		list-style: none;
		background: var(--surface);
		color: var(--text);
	}

	.project-category summary::-webkit-details-marker {
		display: none;
	}

	.project-category summary::marker {
		content: '';
	}

	.summary-content {
		display: grid;
		gap: 1rem;
	}

	.project-category h2 {
		margin: 0;
		color: var(--text);
		font-size: 1.75rem;
		line-height: 1.15;
	}

	.project-category summary p {
		margin: 0.5rem 0 0;
		color: var(--text-muted);
		line-height: 1.45;
	}

	.summary-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.25rem;
	}

	.count {
		color: var(--text-muted);
		font-size: 0.95rem;
		white-space: nowrap;
	}

	.expand-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem 0.7rem;
		border: 1px solid rgba(var(--accent-light), 0.18);
		border-radius: 999px;
		background: rgba(var(--accent), 0.22);
		color: rgb(var(--accent-light));
		font-size: 0.85rem;
		font-weight: 800;
		line-height: 1;
	}

	.hide-text {
		display: none;
	}

	.project-category[open] .show-text {
		display: none;
	}

	.project-category[open] .hide-text {
		display: inline;
	}

	.project-reveal {
		padding: 1.25rem;
		border-top: 1px solid var(--border);
		background: var(--surface-soft);
	}

	.project-category[open] .project-reveal {
		animation: revealProjects 250ms ease-out both;
	}

	.project-list {
		display: grid;
		gap: 1rem;
	}

	.project-card {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1.25rem;
		align-items: start;
		padding: 1rem;
		border: 1px solid var(--border);
		border-radius: 12px;
		background: var(--surface-tinted);
		color: var(--text);
	}

	.project-card.has-image {
		grid-template-columns: minmax(0, 1fr) 190px;
	}

	.project-copy {
		min-width: 0;
	}

	.project-card-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 0.65rem;
	}

	.status {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin: 0;
		padding: 0.25rem 0.55rem;
		border: 1px solid rgba(var(--accent-light), 0.18);
		border-radius: 999px;
		background: rgba(var(--accent), 0.16);
		color: rgb(var(--accent-light));
		font-size: 0.75rem;
		font-weight: 800;
		line-height: 1;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.project-link,
	.coverage-link {
		color: rgb(var(--accent-light));
		font-weight: 800;
		text-decoration: none;
	}

	.project-link {
		white-space: nowrap;
	}

	.coverage-link {
		display: inline-flex;
		width: fit-content;
		margin-top: 0.75rem;
		font-size: 0.9rem;
	}

	.project-link:hover,
	.coverage-link:hover {
		color: var(--text);
		text-decoration: underline;
	}

	.project-link.muted {
		color: var(--text-muted);
		font-weight: 700;
	}

	.project-card h3 {
		margin: 0 0 0.5rem;
		color: var(--text);
		font-size: 1.2rem;
		line-height: 1.2;
	}

	.project-description {
		margin: 0;
		color: var(--text-soft);
		line-height: 1.55;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 0.9rem;
	}

	.tag {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.28rem 0.6rem;
		border: 1px solid rgba(var(--accent-light), 0.18);
		border-radius: 999px;
		background: rgba(var(--accent), 0.2);
		color: rgb(var(--accent-light));
		font-size: 0.76rem;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
	}

	.tag:hover {
		background: rgba(var(--accent), 0.3);
		color: var(--text);
	}

	.project-side {
		display: grid;
		gap: 0.75rem;
		justify-items: end;
		align-content: start;
	}

	.side-link {
		text-align: right;
	}

	.project-image-wrap {
		width: 190px;
		height: 190px;
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 12px;
		background: var(--surface-raised);
	}

	.project-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 50% 38%;
		border-radius: 0;
		transform: scale(3.6);
		transform-origin: 50% 38%;
	}

	@keyframes revealProjects {
		from {
			opacity: 0;
			transform: translateY(-0.5rem);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 720px) {
		main {
			padding: 2rem 1rem;
		}

		.count {
			display: none;
		}

		.project-category summary {
			padding: 1rem;
		}

		.project-reveal {
			padding: 1rem;
		}

		.project-card.has-image {
			grid-template-columns: 1fr;
		}

		.project-card-header {
			flex-direction: column;
			gap: 0.6rem;
		}

		.project-link {
			white-space: normal;
		}

		.project-side {
			justify-items: start;
		}

		.side-link {
			text-align: left;
		}

		.project-image-wrap {
			width: 100%;
			height: 220px;
		}

		.project-image {
			object-position: 50% 38%;
			transform: scale(2.5);
			transform-origin: 50% 38%;
		}
	}
</style>