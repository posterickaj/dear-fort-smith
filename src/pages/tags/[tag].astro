---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	const allTags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))].sort();

return allTags.map((tag) => ({
	params: { tag },
	props: {
		tag,
		allTags,
		posts: posts
			.filter((post) => post.data.tags?.includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
	},
}));
}

const { tag, allTags, posts } = Astro.props;

const formatTag = (tag: string) =>
	tag
		.replaceAll('-', ' ')
		.replace(/\b\w/g, (letter) => letter.toUpperCase());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${formatTag(tag)} | Dear Fort Smith,`}
			description={`Articles tagged ${formatTag(tag)}.`}
		/>
	</head>

	<body>
		<Header />
		<main>
			<p class="eyebrow">Platform Tag</p>
			<h1>{formatTag(tag)}</h1>

			<p class="intro">
				Articles connected to this Dear Fort Smith, platform topic.
			</p>

			<ul class="article-list">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							{post.data.heroImage && (
								<img src={post.data.heroImage} alt="" />
							)}

							<div>
								<h2>{post.data.title}</h2>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<p>{post.data.description}</p>
							</div>
						</a>
					</li>
				))}
			</ul>
            <section class="other-tags">
	<h2>Explore other tags</h2>

	<div class="other-tag-list">
		{allTags
			.filter((otherTag) => otherTag !== tag)
			.map((otherTag) => (
				<a class="other-tag-pill" href={`/tags/${otherTag}`}>
					{formatTag(otherTag)}
				</a>
			))}
	</div>

	<p class="platform-link">
		<a href={`/platform#${tag}`}>View this tag in the platform →</a>
	</p>
</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 900px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	h1 {
		margin-bottom: 1rem;
	}

	.intro {
		margin-bottom: 2rem;
		font-size: 1.1rem;
		line-height: 1.6;
	}

	.article-list {
		display: grid;
		gap: 1.25rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.article-list li {
		border: 1px solid rgba(var(--black), 0.12);
		border-radius: 12px;
		background: white;
		overflow: hidden;
	}

	.article-list a {
		display: grid;
		grid-template-columns: 220px 1fr;
		gap: 1rem;
		padding: 1rem;
		color: inherit;
		text-decoration: none;
	}

	.article-list img {
		width: 100%;
		height: 140px;
		object-fit: contain;
		background: black;
		border-radius: 8px;
	}

	.article-list h2 {
		margin: 0 0 0.4rem;
	}

	.date {
		margin: 0 0 0.5rem;
		color: rgb(var(--gray));
	}

	.article-list p {
		line-height: 1.5;
	}

	.article-list a:hover h2 {
		color: rgb(var(--accent));
	}

	@media (max-width: 720px) {
		.article-list a {
			grid-template-columns: 1fr;
		}
	}
    .other-tags {
	margin-top: 3rem;
	padding-top: 1.5rem;
	border-top: 1px solid rgba(var(--black), 0.12);
}

.other-tags h2 {
	margin-bottom: 1rem;
}

.tag-list {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
}

.tag-list a {
	display: inline-block;
	padding: 0.35rem 0.7rem;
	border-radius: 999px;
	background: rgba(var(--accent), 0.12);
	color: var(--accent);
	font-size: 0.85rem;
	font-weight: 700;
	text-decoration: none;
}

.tag-list a:hover {
	background: rgba(var(--accent), 0.2);
}

.platform-link {
	margin-top: 1.5rem;
}
.other-tags {
	margin-top: 4rem;
	padding-top: 2rem;
	border-top: 1px solid rgba(var(--black), 0.12);
}

.other-tags h2 {
	margin: 0 0 1.25rem;
	font-size: 2rem;
}

.other-tag-list {
	display: flex;
	flex-wrap: wrap;
	gap: 0.65rem;
}

.other-tag-pill {
	display: inline-block;
	padding: 0.4rem 0.75rem;
	border-radius: 999px;
	background: rgba(var(--accent), 0.12);
	color: var(--accent);
	font-size: 0.9rem;
	font-weight: 700;
	text-decoration: none;
	line-height: 1;
}

.other-tag-pill:hover {
	background: rgba(var(--accent), 0.22);
}

.platform-link {
	margin-top: 1.75rem;
}

.platform-link a {
	color: var(--accent);
	font-weight: 700;
	text-decoration: none;
}

.platform-link a:hover {
	text-decoration: underline;
}
</style>